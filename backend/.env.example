DATABASE_URL=postgresql://user:password@localhost:5432/stnk_bureau
NODE_ENV=development
PORT=3000

# JWT
JWT_ACCESS_SECRET=your_jwt_access_secret_change_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6379

# Storage
INVOICE_STORAGE_PATH=./storage/invoices
TENANT_LOGO_STORAGE_PATH=./uploads/tenant-logos

# App URLs
APP_URL=http://localhost:3000
TRACKING_URL=http://localhost:3001/tracking
FRONTEND_URL=http://localhost:3001

# CORS
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# WhatsApp API (optional, for actual integration)
WHATSAPP_API_URL=
WHATSAPP_API_KEY=

# Sambara PKB API
SAMBARA_PKB_API_URL=https://sambara-v2.bapenda.jabarprov.go.id/api/renew-sambara/v2/get-info-pkb-v2
SAMBARA_PKB_BEARER_TOKEN=
SAMBARA_PKB_TIMEOUT_MS=10000
