    "express": "^4.22.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.2",
    "redis": "^4.6.10",
    "twilio": "^6.0.2",
    "uuid": "^9.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@prisma/client": "^7.8.0",
