    "bullmq": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.1.1",
    "pdfkit": "^0.15.0",
    "pg": "^8.11.2",
    "uuid": "^9.0.0",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
