generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum Role {
  SUPER_ADMIN
  OWNER
  ADMIN
}

enum TransactionStatus {
  DRAFT
  ON_PROCESS
  READY_TO_PICKUP
  COMPLETED
  CLOSED
}

enum PaymentType {
  DP
  FINAL_PAYMENT
  REFUND
}

enum PaymentMethod {
  CASH
}

enum WhatsappStatus {
  PENDING
  SENT
  FAILED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Tenant {
  id                  String             @id @default(uuid())
  code                String             @unique
  name                String
  logoUrl             String?
  phone               String?
  address             String?
  subscriptionStart   DateTime
  subscriptionEnd     DateTime
  subscriptionStatus  SubscriptionStatus @default(ACTIVE)
  isActive            Boolean            @default(true)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  users            User[]
  refreshTokenSessions RefreshTokenSession[]
  userDeviceTokens UserDeviceToken[]
  branches         Branch[]
  customers        Customer[]
  vehicles         Vehicle[]
  transactions     Transaction[]
  transactionDocuments TransactionDocument[]
  serviceTypes     ServiceType[]
  pricingRules     PricingRule[]
  masterFeeRules   MasterFeeRule[]
  documentRequirements MasterServiceDocumentRequirement[]
  invoiceSequences InvoiceSequence[]
  whatsappQueues   WhatsappQueue[]
  auditLogs        AuditLog[]
  subscriptions    Subscription[]

  @@map("tenants")
}

model Branch {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  address   String?
  phone     String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  users        User[]
  transactions Transaction[]

  @@index([tenantId])
  @@index([deletedAt])
  @@map("branches")
}

model User {
  id           String    @id @default(uuid())
  tenantId     String
  branchId     String?
  name         String
  email        String    @unique
  passwordHash String
  role         Role
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  branch    Branch?    @relation(fields: [branchId], references: [id])
  auditLogs AuditLog[]
  refreshTokenSessions RefreshTokenSession[]
  deviceTokens UserDeviceToken[]

  @@index([tenantId])
  @@index([deletedAt])
  @@map("users")
}

model Customer {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  phone     String
  email     String?
  address   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  vehicles     Vehicle[]
  transactions Transaction[]

  @@index([tenantId])
  @@index([phone])
  @@index([deletedAt])
  @@map("customers")
}

model Vehicle {
  id               String    @id @default(uuid())
  tenantId         String
  customerId       String
  plateNumber      String
  model            String?
  brand            String?
  color            String?
  engineNumber     String?
  chassisNumber    String?
  registrationYear Int?
  stnkExpiryDate   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  customer         Customer          @relation(fields: [customerId], references: [id])
  transactionItems TransactionItem[]

  @@index([tenantId])
  @@index([tenantId, plateNumber])
  @@index([stnkExpiryDate])
  @@index([plateNumber])
  @@index([deletedAt])
  @@map("vehicles")
}

model ServiceType {
  id          String   @id @default(uuid())
  name        String
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // null tenantId = global service type managed by super admin
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  transactionItems TransactionItem[]
  pricingRules         PricingRule[]
  masterFeeRules      MasterFeeRule[]
  documentRequirements MasterServiceDocumentRequirement[]

  @@index([deletedAt])
  @@map("service_types")
}

model MasterVehicleType {
  id         String   @id @default(uuid())
  code       String   @unique
  name       String
  priceGroup String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([priceGroup])
  @@map("m_vehicle_types")
}

model MasterFeeComponent {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("m_fee_components")
}

model MasterFeeRule {
  id              String   @id @default(uuid())
  tenantId        String?
  provinceCode    String   @default("JABAR")
  cityCode        String?
  serviceTypeId   String
  vehicleTypeCode String
  priceGroup      String
  componentCode   String
  componentName   String
  defaultAmount   Decimal  @db.Decimal(15, 2) @default(0)
  isEditable      Boolean  @default(true)
  isRequired      Boolean  @default(true)
  sortOrder       Int      @default(0)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  tenant      Tenant?     @relation(fields: [tenantId], references: [id])
  serviceType ServiceType @relation(fields: [serviceTypeId], references: [id])

  @@index([tenantId, provinceCode, serviceTypeId, vehicleTypeCode])
  @@index([tenantId, provinceCode, serviceTypeId, priceGroup])
  @@index([componentCode])
  @@index([deletedAt])
  @@map("m_fee_rules")
}

model MasterServiceDocumentRequirement {
  id           String   @id @default(uuid())
  tenantId     String?
  serviceTypeId String
  documentCode String
  documentName String
  isRequired   Boolean  @default(true)
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant      Tenant?     @relation(fields: [tenantId], references: [id])
  serviceType ServiceType @relation(fields: [serviceTypeId], references: [id])

  @@index([tenantId, serviceTypeId])
  @@index([documentCode])
  @@map("m_service_document_requirements")
}

model PricingRule {
  id            String   @id @default(uuid())
  tenantId      String
  serviceTypeId String
  price         Decimal  @db.Decimal(15, 2)
  marginAmount  Decimal  @db.Decimal(15, 2) @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  serviceType ServiceType @relation(fields: [serviceTypeId], references: [id])

  @@unique([tenantId, serviceTypeId])
  @@index([tenantId])
  @@index([deletedAt])
  @@map("pricing_rules")
}

model Transaction {
  id                  String            @id @default(uuid())
  tenantId            String
  branchId            String
  customerId          String
  invoiceNumber       String            @unique
  trackingCode        String            @unique
  status              TransactionStatus @default(DRAFT)
  estimatedTotal      Decimal           @db.Decimal(15, 2) @default(0)
  finalTotal          Decimal           @db.Decimal(15, 2) @default(0)
  baseCostTotal       Decimal           @db.Decimal(15, 2) @default(0)
  serviceFeeTotal     Decimal           @db.Decimal(15, 2) @default(0)
  dpAmount            Decimal           @db.Decimal(15, 2) @default(0)
  remainingAmount     Decimal           @db.Decimal(15, 2) @default(0)
  refundAmount        Decimal           @db.Decimal(15, 2) @default(0)
  estimatedFinishDate DateTime?
  invoicePath         String?
  notes               String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  deletedAt           DateTime?

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  branch   Branch   @relation(fields: [branchId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  items    TransactionItem[]
  payments Payment[]
  logs     TransactionLog[]

  @@index([tenantId])
  @@index([branchId])
  @@index([status])
  @@index([invoiceNumber])
  @@index([trackingCode])
  @@index([deletedAt])
  @@map("transactions")
}

model TransactionItem {
  id            String   @id @default(uuid())
  tenantId      String
  transactionId String
  vehicleId     String
  serviceTypeId String
  price         Decimal  @db.Decimal(15, 2)
  baseCost      Decimal  @db.Decimal(15, 2) @default(0)
  serviceFee    Decimal  @db.Decimal(15, 2) @default(0)
  createdAt     DateTime @default(now())

  transaction       Transaction                        @relation(fields: [transactionId], references: [id])
  vehicle           Vehicle                            @relation(fields: [vehicleId], references: [id])
  serviceType       ServiceType                        @relation(fields: [serviceTypeId], references: [id])
  feeDetails        TransactionItemFeeDetail[]
  documentChecklist TransactionItemDocumentChecklist[]
  documents         TransactionDocument[]

  @@index([tenantId])
  @@index([tenantId, transactionId])
  @@map("transaction_items")
}

model TransactionItemFeeDetail {
  id                String   @id @default(uuid())
  transactionItemId String
  componentCode     String
  componentName     String
  defaultAmount     Decimal  @db.Decimal(15, 2) @default(0)
  amount            Decimal  @db.Decimal(15, 2) @default(0)
  isEditable        Boolean  @default(true)
  source            String   @default("master")
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  transactionItem TransactionItem @relation(fields: [transactionItemId], references: [id], onDelete: Cascade)

  @@index([transactionItemId])
  @@index([componentCode])
  @@map("transaction_item_fee_details")
}

model TransactionItemDocumentChecklist {
  id                String    @id @default(uuid())
  transactionItemId String
  documentCode      String
  documentName      String
  isRequired        Boolean   @default(true)
  isChecked         Boolean   @default(false)
  checkedAt         DateTime?
  checkedBy         String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  transactionItem TransactionItem @relation(fields: [transactionItemId], references: [id], onDelete: Cascade)

  @@index([transactionItemId])
  @@index([documentCode])
  @@map("transaction_item_document_checklists")
}

model TransactionDocument {
  id                String    @id @default(uuid())
  tenantId          String
  transactionItemId String
  documentCode      String
  fileName          String
  fileUrl           String
  mimeType          String
  sizeBytes         Int
  uploadedBy        String
  createdAt         DateTime  @default(now())
  deletedAt         DateTime?

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  transactionItem TransactionItem @relation(fields: [transactionItemId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([transactionItemId])
  @@index([documentCode])
  @@map("transaction_documents")
}

model Payment {
  id            String        @id @default(uuid())
  tenantId      String
  transactionId String
  amount        Decimal       @db.Decimal(15, 2)
  type          PaymentType
  method        PaymentMethod @default(CASH)
  notes         String?
  createdAt     DateTime      @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@index([tenantId])
  @@index([tenantId, transactionId])
  @@index([transactionId])
  @@map("payments")
}

model InvoiceSequence {
  id       String @id @default(uuid())
  tenantId String
  year     Int
  month    Int
  lastSeq  Int    @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, year, month])
  @@map("invoice_sequences")
}

model TransactionLog {
  id            String   @id @default(uuid())
  tenantId      String
  transactionId String
  fromStatus    String?
  toStatus      String
  notes         String?
  createdBy     String?
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@index([tenantId])
  @@index([tenantId, transactionId])
  @@map("transaction_logs")
}

model UserDeviceToken {
  id        String   @id @default(uuid())
  userId    String
  tenantId  String
  token     String   @unique
  platform  String
  deviceId  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([tenantId])
  @@index([isActive])
  @@map("user_device_tokens")
}

model RefreshTokenSession {
  id           String    @id @default(uuid())
  userId       String
  tenantId     String
  tokenHash    String    @unique
  family       String
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([tenantId])
  @@index([family])
  @@index([expiresAt])
  @@map("refresh_token_sessions")
}

model Subscription {
  id        String             @id @default(uuid())
  tenantId  String
  planName  String
  startDate DateTime
  endDate   DateTime
  price     Decimal            @db.Decimal(15, 2)
  status    SubscriptionStatus @default(ACTIVE)
  createdAt DateTime           @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("subscriptions")
}

model WhatsappQueue {
  id         String         @id @default(uuid())
  tenantId   String?
  phone      String
  message    String
  mediaUrl   String?
  status     WhatsappStatus @default(PENDING)
  attempts   Int            @default(0)
  maxRetries Int            @default(5)
  error      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([status])
  @@map("whatsapp_queue")
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String?
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  createdBy String?
  ipAddress String?
  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  user   User?   @relation(fields: [createdBy], references: [id])

  @@index([tenantId])
  @@index([entity])
  @@map("audit_logs")
}
