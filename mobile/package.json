{
  "name": "stnk-bureau-mobile",
  "version": "1.0.0",
  "description": "SatuJasa Service Management System - Mobile App",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "eas build",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "1.21.0",
    "@react-native-camera-roll/camera-roll": "^7.4.0",
    "@sentry/react-native": "^8.12.0",
    "@tanstack/react-query": "^5.100.10",
    "@types/react": "~18.2.45",
    "axios": "^1.6.0",
    "expo": "~50.0.20",
    "expo-camera": "~14.1.3",
    "expo-constants": "15.4.6",
    "expo-device": "^55.0.17",
    "expo-image-picker": "~14.7.1",
    "expo-linking": "~6.2.2",
    "expo-module-gradle-plugin": "^1.0.0",
    "expo-notifications": "^55.0.23",
    "expo-router": "~3.4.10",
    "expo-sharing": "~11.10.0",
    "expo-status-bar": "~1.11.1",
    "react": "^18.2.0",
    "react-hook-form": "^7.75.0",
    "react-native": "0.73.6",
    "react-native-paper": "^5.12.0",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "~3.29.0",
    "zod": "^3.22.0",
    "zustand": "^4.4.5"
  },
  "devDependencies": {
    "@react-native-community/cli-server-api": "12.3.6",
    "@types/react": "~18.2.45",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.55.0",
    "typescript": "^5.3.3"
  },
  "expo": {
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow access to camera for document scanning"
        }
      ]
    ]
  }
}
